 #include <stdio.h>
#include <string.h>

#define MAX 10000   // Maximum size for large paragraph input

// Function to check palindrome
int isPalindrome(char str[], int start, int end) {

    // Compare characters from both ends
    while (start < end) {

        // If characters don't match
        if (str[start] != str[end])
            return 0;

        // Move indexes
        start++;
        end--;
    }

    // Palindrome found
    return 1;
}

// Function to find palindromes
void findPalindromes(char str[]) {

    int n = strlen(str);
    int maxLength = 0, startIndex = 0;
    int found = 0;

    printf("\nPalindromic substrings:\n");

    // Generate all substrings
    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            // Check palindrome
            if (isPalindrome(str, i, j)) {

                found = 1;

                // Print palindrome
                for (int k = i; k <= j; k++)
                    printf("%c", str[k]);

                printf("\n");

                // Store longest palindrome
                if ((j - i + 1) > maxLength) {

                    maxLength = j - i + 1;
                    startIndex = i;
                }
            }
        }
    }

    // Print longest palindrome
    if (found) {

        printf("\nLongest Palindrome: ");

        for (int i = startIndex;
             i < startIndex + maxLength;
             i++) {

            printf("%c", str[i]);
        }

        printf("\n");
    }
    else {

        printf("No palindrome found.\n");
    }
}

// Function for pattern searching
void patternSearch(char text[], char pattern[]) {

    int n = strlen(text);
    int m = strlen(pattern);
    int found = 0;

    printf("\nPattern found at positions: ");

    // Traverse text
    for (int i = 0; i <= n - m; i++) {

        int j;

        // Compare pattern
        for (j = 0; j < m; j++) {

            if (text[i + j] != pattern[j])
                break;
        }

        // Pattern found
        if (j == m) {

            printf("%d ", i);
            found = 1;
        }
    }

    // If not found
    if (!found)
        printf("None");

    printf("\n");
}

// Main function
int main() {

    char str[MAX];          // Large string array
    char line[1000];        // Temporary line storage
    char pattern[100];

    // Initialize empty string
    str[0] = '\0';

    printf("Enter  paragraph:\n");
    printf("(Type END on a new line to stop input)\n\n");

    // Read multiple lines
    while (1) {

        // Read one full line
        fgets(line, sizeof(line), stdin);

        // Stop if user types END
        if (strncmp(line, "END", 3) == 0)
            break;

        // Append line to main string
        strcat(str, line);
    }

    // Find palindromes
    findPalindromes(str);

    // Input pattern
    printf("\nEnter pattern to search:\n");

    // Read full pattern with spaces
    fgets(pattern, sizeof(pattern), stdin);

    // Remove newline from pattern
    pattern[strcspn(pattern, "\n")] = '\0';

    // Search pattern
    patternSearch(str, pattern);

    return 0;
}
