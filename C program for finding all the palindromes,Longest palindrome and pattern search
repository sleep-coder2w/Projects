#include <stdio.h>
#include <string.h>

// Function to check palindrome
int isPalindrome(char str[], int start, int end) {
    while (start < end) {
        if (str[start] != str[end])
            return 0;
        start++;
        end--;
    }
    return 1;
}

// Function to find all palindromes
void findPalindromes(char str[]) {
    int n = strlen(str);
    int maxLength = 0, startIndex = 0;
    int found = 0;

    printf("\nPalindromic substrings (length >= 2):\n");

    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {

            if (isPalindrome(str, i, j)) {

                found = 1;

                // Print palindrome
                for (int k = i; k <= j; k++) {
                    printf("%c", str[k]);
                }

                printf("\n");

                // Check longest palindrome
                if ((j - i + 1) > maxLength) {
                    maxLength = j - i + 1;
                    startIndex = i;
                }
            }
        }
    }

    if (found) {
        printf("\nLongest Palindrome: ");

        for (int i = startIndex;
             i < startIndex + maxLength;
             i++) {

            printf("%c", str[i]);
        }

        printf("\n");
    }
    else {
        printf("No palindrome found.\n");
    }
}

// Function for pattern search
void patternSearch(char text[], char pattern[]) {

    int n = strlen(text);
    int m = strlen(pattern);
    int found = 0;

    printf("\nPattern found at positions: ");

    for (int i = 0; i <= n - m; i++) {

        int j;

        for (j = 0; j < m; j++) {

            if (text[i + j] != pattern[j]) {
                break;
            }
        }

        if (j == m) {
            printf("%d ", i);
            found = 1;
        }
    }

    if (!found) {
        printf("None");
    }

    printf("\n");
}

// Main Function
int main() {

    char str[1000];
    char pattern[100];

    // Input string with spaces
    printf("Enter a string:\n");
    scanf(" %[^\n]", str);

    // Find palindromes
    findPalindromes(str);

    // Pattern input with spaces
    printf("\nEnter pattern to search:\n");
    scanf(" %[^\n]", pattern);

    // Pattern search
    patternSearch(str, pattern);

    return 0;
}
